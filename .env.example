# latch402 core
NODE_ENV=production
PORT=4020
CORS_ORIGIN=*
LATCH402_PUBLIC_BASE_URL=https://your-domain.example
LATCH402_DB_PATH=.data/latch402.db

# OKX production payment gate. In production, auto enables OKX. Use off only for local development.
LATCH402_PAYMENT_MODE=auto
PAY_TO_ADDRESS=0x0000000000000000000000000000000000000000
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_FACILITATOR_BASE_URL=https://web3.okx.com
OKX_SYNC_SETTLE=false
X402_NETWORK=eip155:196
X402_PRICE_USD=0.05

# Scanner safety
TARGET_ALLOWLIST=
SCAN_TIMEOUT_MS=12000
SCAN_MAX_BODY_BYTES=65536
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# Optional active buyer probes. Start on X Layer testnet.
SCAN_ACTIVE_PAYMENTS_ENABLED=false
SCAN_SPEND_CAP_USD=0.10
EVM_PRIVATE_KEY=
X402_ACTIVE_NETWORK=eip155:1952
# Use https://testrpc.xlayer.tech when X402_ACTIVE_NETWORK=eip155:1952.
# Use https://rpc.xlayer.tech when X402_ACTIVE_NETWORK=eip155:196.
X_LAYER_RPC_URL=https://testrpc.xlayer.tech
